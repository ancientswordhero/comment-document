#!/bin/sh
# ----------------------------------------------------------------------------
# Maven Wrapper startup script
# ----------------------------------------------------------------------------

# Determine project directory
PRG="$0"
while [ -h "$PRG" ]; do
  ls=$(ls -ld "$PRG")
  link=$(expr "$ls" : '.*-> \(.*\)$')
  if expr "$link" : '/.*' > /dev/null; then
    PRG="$link"
  else
    PRG=$(dirname "$PRG")/"$link"
  fi
done
SAVED="$(pwd)"
cd "$(dirname "$PRG")/" >/dev/null
PROJECT_DIR="$(pwd -P)"

# Find JAVA_HOME
if [ -z "$JAVA_HOME" ]; then
    JAVA_HOME=$(java -XshowSettings:properties -version 2>&1 | grep "java.home" | awk -F'= ' '{print $2}' 2>/dev/null | tr -d '\r')
    if [ -z "$JAVA_HOME" ]; then
        echo "ERROR: JAVA_HOME could not be determined. Please set JAVA_HOME."
        exit 1
    fi
fi
export JAVA_HOME

# Locate Maven distribution
MAVEN_DIST_DIR="$HOME/.m2/wrapper/dists/apache-maven-3.9.6-bin"
if [ -d "$MAVEN_DIST_DIR" ]; then
    MAVEN_HOME=$(ls -d "$MAVEN_DIST_DIR"/*/apache-maven-3.9.6 2>/dev/null | head -1)
fi

if [ -z "$MAVEN_HOME" ] || [ ! -f "$MAVEN_HOME/bin/mvn" ]; then
    echo "Maven distribution not found. Downloading..."
    MAVEN_ZIP="$HOME/.m2/wrapper/maven-dist.zip"
    MAVEN_URL="https://repo.maven.apache.org/maven2/org/apache/maven/apache-maven/3.9.6/apache-maven-3.9.6-bin.zip"
    mkdir -p "$(dirname "$MAVEN_ZIP")"
    if command -v curl >/dev/null 2>&1; then
        curl -L -o "$MAVEN_ZIP" "$MAVEN_URL"
    elif command -v wget >/dev/null 2>&1; then
        wget -O "$MAVEN_ZIP" "$MAVEN_URL"
    else
        echo "ERROR: curl or wget required to download Maven."
        exit 1
    fi
    mkdir -p "$MAVEN_DIST_DIR"
    unzip -qo "$MAVEN_ZIP" -d "$MAVEN_DIST_DIR"
    rm -f "$MAVEN_ZIP"
    MAVEN_HOME="$MAVEN_DIST_DIR/apache-maven-3.9.6"
fi

# Run Maven
cd "$SAVED"
exec "$MAVEN_HOME/bin/mvn" \
    -Dmaven.multiModuleProjectDirectory="$PROJECT_DIR" \
    "$@"
